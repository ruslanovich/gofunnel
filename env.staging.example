# Staging environment template for VPS deployment.
# Copy to `env.staging` on the VPS (do not commit real secrets).

# Database
DATABASE_URL=postgresql://postgres:password@db.example.internal:5432/postgres
PORT=3000
APP_ORIGIN=https://staging.example.com
NODE_ENV=production

# Auth / token hashing
TOKEN_HASH_PEPPER=change-me-long-random-secret
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=

# Auth placeholders
AUTH_PROVIDER=placeholder
AUTH_SECRET=change-me
AUTH_CLIENT_ID=placeholder
AUTH_CLIENT_SECRET=placeholder
AUTH_CALLBACK_URL=https://staging.example.com/api/auth/callback

# Yandex Object Storage (Yandex Cloud Kazakhstan)
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=kz1
S3_BUCKET=your-staging-bucket
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-5-mini
LLM_API_KEY=your-openai-api-key
LLM_TIMEOUT_MS=20000

# Worker
WORKER_CONCURRENCY=2
WORKER_POLL_MS=1000
WORKER_LLM_TIMEOUT_MS=240000
WORKER_OPENAI_LOG_LEVEL=off
WORKER_ID=
